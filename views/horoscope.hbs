<style>

:root {
  background-color: #000000; 
  color: #ffffff;           
  color-scheme: dark;  
}

html, body {
    height: 100% !important;
    margin: 0;
}

body {
    margin: 0;       
    padding: 0;
    min-height: 100vh; 
    background-color: #000000;
}

table {
    width: 1000px;
    margin: 50px auto;
    border-collapse: collapse;
    background: rgba(255, 255, 255, 0); 
    backdrop-filter: blur(10px);         
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

table th {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    padding: 14px;
    text-transform: uppercase;
    font-size: 20px;
    text-align: center;
    letter-spacing: 1px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

table td {
    background: rgba(255, 255, 255, 0.1);
    padding: 12px 15px;
    color: rgba(255, 255, 255, 0.9);
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 20px;
}

table tr:hover {
    background: rgba(255, 255, 255, 0.1);
    transition: 0.3s;
}

.btn-list {
    margin-left: 850px;
    margin-top: 200px;
    color:rgb(255, 255, 255);
}

.btn-generate {
    display: block;
    width: 100px;
    margin: 20px auto;
    margin-top: 10px;
    padding: 10px;
    background: #28a745;
    color: white;
    text-decoration: none;
    text-align: center;
    border-radius: 8px;
    font-weight: bold;
    box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
    border: 1px solid aliceblue;
}
    
</style>
        </button>
            <h1 class="btn-list">HOROSCOPE</h1>
                <table>
                    <thead>
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">SIGN</th>
                            <th scope="col">MONTH</th>
                            <th scope="col">TEXT</th>
                        </tr>
                    </thead>
                        <tbody>
                            {{#each horoscope }}
                                <tr>
                                    <th scope="row">{{this.id}}</th>
                                    <td>{{this.sign}}</td>
                                    <td>{{this.month}}</td>
                                    <td>{{this.text}}</td>
                                </tr>
                            {{/each}}
                        </tbody>
                    </table>
                <div><a href="/generate" class="btn-generate" >GENERATE</a></div>
            </body>

<head>
  <style>
    body {
      background: black;
    }
    h1 {
      color: white;
    }
    button {
      position: fixed;
      bottom: 20px;
      right: 20px;
      padding: 10px 20px;
      font-size: 16px;
      cursor: pointer;
      background: none;
      border: none;
      color: white;
    }
  </style>
</head>
