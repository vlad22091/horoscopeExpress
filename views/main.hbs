<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Horoscope</title>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      background: #0a0a1a;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: Georgia, serif;
    }

    h1 {
      color: #c9a96e;
      font-size: 10rem;
      letter-spacing: 0.1em;
      margin-bottom: 3rem;
      text-align: center;
      margin-top: -7vh;
    }

    .btn-generate {
      background: #c9a96e;
      color: #0a0a1a;
      border: none;
      font-weight: bold;
      text-decoration: none;
      padding: 1.2rem 2rem;
      font-size: 1.3rem;
      font-family: Georgia, serif;
      border-radius: 20px;
      letter-spacing: 0.1em;
      cursor: pointer;
    }

    .btn-history {
      position: absolute;
      bottom: 20px;
      right: 20px;
      background: #c9a96e;
      color: #0a0a1a;
      border: none;
      text-decoration: none;
      padding: 0.5rem 1rem;
      font-size: 1rem;
      font-family: Georgia, serif;
      letter-spacing: 0.1em;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <h1>Horoscope</h1>
<div><a href="/generate" class="btn-generate">Generate</a></div>
<div><a href="/db" class="btn-history">History</a></div>
</body>
</html>
